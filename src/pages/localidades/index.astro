---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import type { CollectionEntry } from 'astro:content';

const servicios = (await getCollection('servicios')).sort((a, b) => a.data.title.localeCompare(b.data.title));
const localidades = (await getCollection('localidades')).sort((a, b) => a.data.nombre.localeCompare(b.data.nombre));

const title = 'Localidades en España · EMBES';
const metaDescription = 'Listado de municipios españoles donde EMBES dispone de landings de servicios profesionales y urgentes Rank & Rent.';
const canonical = new URL('/localidades/', 'https://www.embes.es').href;
---
<Base title={title} metaDescription={metaDescription} canonical={canonical}>
  <section class="space-y-8">
    <div class="space-y-3">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Localidades atendidas</h1>
      <p class="text-lg text-muted-foreground max-w-2xl">
        Nodo central de localidades. Cada municipio enlaza directamente a landings transaccionales de cada servicio.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {localidades.map((l: CollectionEntry<'localidades'>) => (
        <div class="space-y-3">
          <h2 class="text-xl font-semibold"><a href={`/servicios/${servicios[0].slug}/${l.slug}/`} class="hover:underline">{l.data.nombreFormal}</a></h2>
          <ul class="space-y-1 text-sm">
            {servicios.map((s: CollectionEntry<'servicios'>) => (
              <li>
                <a
                  href={`/servicios/${s.slug}/${l.slug}/`}
                  class="text-muted-foreground transition-colors hover:text-foreground hover:underline"
                >
                  {s.data.title} en {l.data.nombre}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Base>
