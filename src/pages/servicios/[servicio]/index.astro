---
import { getCollection, render } from 'astro:content';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import Base from '@/layouts/Base.astro';
import type { CollectionEntry } from 'astro:content';

/**
 * EMBES · servicios/[servicio]/index.astro — Plantilla informacional NACIONAL.
 * Silo nacional por categoría. Enlaza a cada landing transaccional por ciudad
 * para distribuir autoridad hacia el núcleo Rank & Rent sin canibalización.
 */
export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((s) => ({ params: { servicio: s.slug }, props: { servicio: s } }));
}

const { servicio } = Astro.props as { servicio: CollectionEntry<'servicios'> };
const localidades = (await getCollection('localidades')).sort((a, b) => a.data.nombre.localeCompare(b.data.nombre));

const s = servicio.data;
const title = `${s.title} en España · EMBES`;
const metaDescription = s.metaDescription;
const canonical = new URL(`/servicios/${servicio.slug}/`, 'https://www.embes.es').href;
const { Content } = await render(servicio);
---
<Base title={title} metaDescription={metaDescription} canonical={canonical} ogType="article">
  <article class="space-y-10">
    <header class="space-y-3">
      <p class="text-sm text-muted-foreground"><a href="/servicios/" class="hover:underline">Servicios</a> / {s.title}</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">{s.h1Principal}</h1>
      <p class="text-lg text-muted-foreground max-w-3xl">{s.metaDescription}</p>
    </header>

    <section class="prose prose-neutral max-w-none">
      <Content />
    </section>

    <section class="space-y-4">
      <h2 class="text-xl font-semibold">Servicios de {s.nombreProfesion} disponibles</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {s.serviciosOfrecidos.map((item) => (
          <li class="flex items-start gap-2">
            <span class="mt-1 h-1.5 w-1.5 rounded-full bg-primary" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="space-y-4">
      <h2 class="text-xl font-semibold">{s.title} por ciudad</h2>
      <p class="text-muted-foreground">Contacta con {s.nombreProfesion} verificados en tu localidad:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {localidades.map((l: CollectionEntry<'localidades'>) => (
          <Card class="transition-all duration-embes ease-embes hover:opacity-95 hover:shadow-md">
            <a href={`/servicios/${servicio.slug}/${l.slug}/`} class="block">
              <CardHeader>
                <CardTitle>{s.title} en {l.data.nombre}</CardTitle>
                <CardDescription>{l.data.nombreFormal} · {l.data.provincia}</CardDescription>
              </CardHeader>
            </a>
          </Card>
        ))}
      </div>
    </section>
  </article>
</Base>
